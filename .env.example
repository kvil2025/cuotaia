# Variables de entorno requeridas para CuotaIA
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.

# Obtén tu llave gratis en: https://api.cmfchile.cl/
CMF_API_KEY=tu_clave_cmf_aqui

# Crea tu bot con @BotFather en Telegram
TELEGRAM_TOKEN=tu_token_de_botfather_aqui

# Obtén tu chat ID escribiéndole a @userinfobot
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Dominios CORS permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Protege endpoints /api/telegram/* de acceso externo
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=genera_una_clave_aleatoria_aqui
