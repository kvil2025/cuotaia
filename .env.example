# Variables de entorno para CuotaIA
# Copia como .env y rellena con tus valores reales.
# NUNCA subas .env a Git.

# Obtén tu llave gratis en: https://api.cmfchile.cl/
CMF_API_KEY=tu_clave_cmf_aqui

# Crea tu bot con @BotFather en Telegram
TELEGRAM_TOKEN=tu_token_de_botfather_aqui

# Obtén tu chat ID escribiéndole a @userinfobot
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Dominios CORS permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
